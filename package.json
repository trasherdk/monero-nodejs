{
  "name": "monero-nodejs",
  "version": "4.0.0",
  "description": "A Monero library written in Node.js.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/test/index_test.js",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PsychicCat/monero-nodejs.git"
  },
  "keywords": [
    "Monero",
    "crypto",
    "currency",
    "cryptocurrency",
    "Node.js",
    "monero-wallet-rpc"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PsychicCat/monero-nodejs/issues"
  },
  "homepage": "https://github.com/PsychicCat/monero-nodejs#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}